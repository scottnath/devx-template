---
import { SEO } from 'astro-seo';
import { resolveOgImage, seoConfig } from '../../utils/seoConfig';

export interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  image?: { url: string; alt: string };
  /** Path to a per-page OG image (e.g. blog `ogImage` frontmatter). */
  ogImagePath?: string;
}

const { title, description, ogTitle, image, ogImagePath } = Astro.props;

const descriptionResolved = description ?? seoConfig.description;

const ogImageUrl = ogImagePath
  ? resolveOgImage(ogImagePath)
  : image?.url
    ? resolveOgImage(image.url)
    : resolveOgImage(seoConfig.image.url);
const ogImageWidth = ogImagePath ? 1200 : seoConfig.image.width;
const ogImageHeight = ogImagePath ? 628 : seoConfig.image.height;
const ogImageAlt = ogImagePath ? title : (image?.alt ?? seoConfig.image.alt);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title.replaceAll('"', '')}
      description={descriptionResolved}
      openGraph={{
        basic: {
          title: ogTitle ?? title,
          type: seoConfig.type,
          image: ogImageUrl,
        },
        image: {
          width: ogImageWidth,
          height: ogImageHeight,
          alt: ogImageAlt,
        },
        optional: {
          siteName: seoConfig.siteName,
          description: descriptionResolved,
        },
      }}
      twitter={{
        card: seoConfig.twitter.card,
      }}
    />
    <slot name="head" />
    <style is:global>
      :root {
        color-scheme: light dark;
        font-family: system-ui, sans-serif;
        line-height: 1.6;
      }

      body {
        margin: 0 auto;
        max-width: 52rem;
        padding: 2rem 1.5rem 4rem;
      }

      article :is(h1, h2, h3) {
        line-height: 1.25;
      }

      article pre {
        overflow-x: auto;
        padding: 1rem;
        border-radius: 0.5rem;
        background: color-mix(in srgb, CanvasText 8%, Canvas);
      }

      article code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
